#include "list.h"
#include <stdlib.h>

int is_sorted(t_list *lst, int (*cmp)(int, int))
{
    t_list *tmp = lst;

    while (tmp)
    {
        if (tmp->next && !cmp(tmp->data, tmp->next->data))
            return 0;
        tmp = tmp->next;
    }
    return 1;
}

t_list	*sort_list(t_list* lst, int (*cmp)(int, int))
{
    t_list *tmp;
    t_list *fwd;
    int swap;

    tmp = lst;
    while (tmp)
    {
        fwd = lst->next;
        while(fwd)
        {
            if (!cmp(tmp->data, fwd->data))
            {
                swap = tmp->data;
                tmp->data = fwd->data;
                fwd->data = swap;
            }
            tmp = fwd;
            fwd = tmp->next;
        }
        tmp = lst;
        if (is_sorted(lst, cmp))
            break;
    }
    return lst;
}
